APP_ENV=development
PORT=3001
PUBLIC_APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_DOMAIN=

# Local dev path is relative to apps/api because dev:api runs with that cwd.
# Use an absolute path in deployment, e.g. file:/app/data/lab.sqlite.
DATABASE_URL=file:./data/lab.sqlite
SERVE_WEB=0
WEB_DIST_DIR=../web/dist

EMAIL_PROVIDER=ses
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_NAME=MIRALAB
SES_FROM_EMAIL=no-reply@miralab.tr
SES_REPLY_TO=support@miralab.tr
SES_CONFIGURATION_SET=miralab-lms
DEV_SHOW_OTP=1

REMINDERS_ENABLED=0
BOOKING_START_REMINDER_MINUTES=15
BOOKING_ENDING_REMINDER_MINUTES=15
NOTIFICATION_WORKER_INTERVAL_SECONDS=60

# Optional manual/cron backup script: bun run backup:sqlite
BACKUP_DATABASE_PATH=./data/lab.sqlite
BACKUP_DIR=./data/backups
BACKUP_RETENTION_DAYS=30
