APP_ENV=development
PORT=3001
PUBLIC_APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
# For LAN device testing, append that dev host, e.g.:
# CORS_ORIGINS=http://localhost:5173,http://your-machine.local:5173
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_DOMAIN=

# Optional public whitelabel overrides. Leave unset to use neutral FOSS defaults.
VITE_LAB_APP_TITLE=
VITE_LAB_SHORT_NAME=
VITE_LAB_LAB_NAME=
VITE_LAB_INSTITUTION_NAME=
VITE_LAB_BASE_URL=
VITE_LAB_LOGO_PATH=
VITE_LAB_FAVICON_PATH=
VITE_LAB_PRIMARY_COLOR=
VITE_LAB_TIMEZONE=
VITE_LAB_AUTH_EYEBROW=
VITE_LAB_AUTH_HEADLINE=
VITE_LAB_EMAIL_FROM_NAME=
VITE_LAB_EMAIL_FROM_ADDRESS=
VITE_LAB_EMAIL_SUPPORT_ADDRESS=

# Local dev path is relative to apps/api because dev:api runs with that cwd.
# Use an absolute path in deployment, e.g. file:/app/data/lab.sqlite.
DATABASE_URL=file:./data/lab.sqlite
SERVE_WEB=0
WEB_DIST_DIR=../web/dist

# First admin identity. Local dev falls back to this fixture, production should set a real
# reachable email address. Leave ALLOWED_EMAIL_DOMAINS empty to allow any invited email.
BOOTSTRAP_ADMIN_EMAIL=admin@example.org
BOOTSTRAP_ADMIN_NAME=Lab Admin
ALLOWED_EMAIL_DOMAINS=

# Local dev uses console mail plus DEV_SHOW_OTP=1.
# Production must set EMAIL_PROVIDER=ses and real AWS/SES credentials.
EMAIL_PROVIDER=console
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_NAME=Lab Management System
SES_FROM_EMAIL=no-reply@example.org
SES_REPLY_TO=support@example.org
SES_CONFIGURATION_SET=
DEV_SHOW_OTP=1
OTP_RATE_LIMIT_WINDOW_SECONDS=900
OTP_RATE_LIMIT_MAX_REQUESTS=5

REMINDERS_ENABLED=0
BOOKING_START_REMINDER_MINUTES=15
BOOKING_ENDING_REMINDER_MINUTES=15
NOTIFICATION_WORKER_INTERVAL_SECONDS=60
NOTIFICATION_RETRY_DELAY_MINUTES=5
NOTIFICATION_MAX_ATTEMPTS=3

# Optional manual/cron backup script: bun run backup:sqlite
BACKUP_DATABASE_PATH=./data/lab.sqlite
BACKUP_DIR=./data/backups
BACKUP_RETENTION_DAYS=30
