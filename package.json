{
  "name": "lab-management-system",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "build": "bun run --filter '*' build",
    "backup:sqlite": "sh scripts/backup-sqlite.sh",
    "backup:cron-entry": "sh scripts/backup-cron-entry.sh",
    "backup:cron-install": "bun scripts/install-backup-cron.ts",
    "prepare:caprover-env": "bun scripts/materialize-caprover-env.ts",
    "verify:sqlite-backup": "sh scripts/verify-sqlite-backup.sh",
    "verify:sqlite-restore": "bun scripts/restore-sqlite-backup.ts",
    "verify:caprover-env": "bun scripts/verify-caprover-env.ts",
    "verify:caprover-host": "bun scripts/verify-caprover-host.ts",
    "verify:caprover-package": "bun scripts/verify-caprover-package.ts",
    "verify:deployed-auth-smoke": "bun scripts/verify-deployed-auth-smoke.ts",
    "verify:deployed-reminder-smoke": "bun scripts/verify-deployed-reminder-smoke.ts",
    "verify:deployed-smoke": "bun scripts/verify-deployed-smoke.ts",
    "verify:docker-build": "sh scripts/verify-docker-build.sh",
    "verify:docker-runtime": "sh scripts/verify-docker-runtime.sh",
    "verify:predeploy": "bun run verify:caprover-env && bun run verify:caprover-package && bun run verify:docker-build && bun run verify:docker-runtime && bun run check && bun run build",
    "check": "bun run lint && bun run typecheck && bun run test",
    "full-gate": "bun run check && bun run build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "playwright": "playwright",
    "test": "vitest run",
    "test:api:auth": "vitest run tests/api/auth.test.ts",
    "test:api:bookings": "vitest run tests/api/bookings.test.ts",
    "test:api:env": "vitest run tests/api/env.test.ts",
    "test:api:health": "vitest run tests/api/health.test.ts",
    "test:api:mailer": "vitest run tests/api/mailer.test.ts",
    "test:api:notifications": "vitest run tests/api/notifications.test.ts",
    "test:api:web-fallback": "vitest run tests/api/web-fallback.test.ts",
    "test:db:bookings": "vitest run tests/db/bookings.test.ts",
    "test:db:machines": "vitest run tests/db/machines.test.ts",
    "test:e2e": "bun run build && playwright test",
    "test:scripts:backup-cron": "vitest run tests/scripts/backup-cron-entry.test.ts",
    "test:scripts:caprover-env": "vitest run tests/scripts/caprover-env.test.ts",
    "test:scripts:caprover-host": "vitest run tests/scripts/caprover-host.test.ts",
    "test:scripts:caprover-package": "vitest run tests/scripts/caprover-package.test.ts",
    "test:scripts:deployed-auth-smoke": "vitest run tests/scripts/deployed-auth-smoke.test.ts",
    "test:scripts:deployed-reminder-smoke": "vitest run tests/scripts/deployed-reminder-smoke.test.ts",
    "test:scripts:deployed-smoke": "vitest run tests/scripts/deployed-smoke.test.ts",
    "test:scripts:docker-runtime": "vitest run tests/scripts/docker-runtime.test.ts",
    "test:scripts:install-backup-cron": "vitest run tests/scripts/install-backup-cron.test.ts",
    "test:scripts:materialize-caprover-env": "vitest run tests/scripts/materialize-caprover-env.test.ts",
    "test:scripts:sqlite-backup": "vitest run tests/scripts/sqlite-backup.test.ts",
    "test:web:booking-dialog": "vitest run tests/web/booking-dialog-defaults.test.ts",
    "test:web:calendar": "vitest run tests/web/calendar-geometry.test.ts",
    "test:web:schedule-defaults": "vitest run tests/web/schedule-defaults.test.ts",
    "test:watch": "vitest",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.3.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
