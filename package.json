{
  "name": "lab-management-system",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "build": "bun run --filter '*' build",
    "backup:sqlite": "sh scripts/backup-sqlite.sh",
    "backup:cron-entry": "sh scripts/backup-cron-entry.sh",
    "verify:sqlite-backup": "sh scripts/verify-sqlite-backup.sh",
    "check": "bun run lint && bun run typecheck && bun run test",
    "full-gate": "bun run check && bun run build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "playwright": "playwright",
    "test": "vitest run",
    "test:api:auth": "vitest run tests/api/auth.test.ts",
    "test:api:bookings": "vitest run tests/api/bookings.test.ts",
    "test:api:env": "vitest run tests/api/env.test.ts",
    "test:api:health": "vitest run tests/api/health.test.ts",
    "test:api:mailer": "vitest run tests/api/mailer.test.ts",
    "test:api:notifications": "vitest run tests/api/notifications.test.ts",
    "test:db:bookings": "vitest run tests/db/bookings.test.ts",
    "test:db:machines": "vitest run tests/db/machines.test.ts",
    "test:e2e": "bun run build && playwright test",
    "test:scripts:backup-cron": "vitest run tests/scripts/backup-cron-entry.test.ts",
    "test:scripts:sqlite-backup": "vitest run tests/scripts/sqlite-backup.test.ts",
    "test:web:booking-dialog": "vitest run tests/web/booking-dialog-defaults.test.ts",
    "test:web:calendar": "vitest run tests/web/calendar-geometry.test.ts",
    "test:web:schedule-defaults": "vitest run tests/web/schedule-defaults.test.ts",
    "test:watch": "vitest",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.3.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
