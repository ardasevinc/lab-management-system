# CapRover production env template for the single-container MIRALAB LMS deploy.
# Mount a persistent CapRover directory/volume to /app/data before using this.

APP_ENV=production
NODE_ENV=production
PORT=3001
PUBLIC_APP_URL=https://lms.miralab.tr
CORS_ORIGINS=https://lms.miralab.tr
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_DOMAIN=

VITE_LAB_APP_TITLE=MIRALAB
VITE_LAB_SHORT_NAME=MIRALAB
VITE_LAB_LAB_NAME=Machine Intelligence Research and Applications Lab
VITE_LAB_INSTITUTION_NAME=Izmir Institute of Technology
VITE_LAB_BASE_URL=https://lms.miralab.tr
VITE_LAB_LOGO_PATH=/logo.svg
VITE_LAB_FAVICON_PATH=/favicon.svg
VITE_LAB_PRIMARY_COLOR=#007f67
VITE_LAB_TIMEZONE=Europe/Istanbul
VITE_LAB_AUTH_EYEBROW=GPU workstation access
VITE_LAB_AUTH_HEADLINE=Book tohum for research runs.
VITE_LAB_EMAIL_FROM_NAME=MIRALAB
VITE_LAB_EMAIL_FROM_ADDRESS=no-reply@miralab.tr
VITE_LAB_EMAIL_SUPPORT_ADDRESS=support@miralab.tr

DATABASE_URL=file:/app/data/lab.sqlite
SERVE_WEB=1
WEB_DIST_DIR=/app/apps/web/dist

BOOTSTRAP_ADMIN_EMAIL=<set-in-caprover>
BOOTSTRAP_ADMIN_NAME=<set-in-caprover>
ALLOWED_EMAIL_DOMAINS=

EMAIL_PROVIDER=ses
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=<set-in-caprover>
AWS_SECRET_ACCESS_KEY=<set-in-caprover>
SES_FROM_NAME=MIRALAB
SES_FROM_EMAIL=no-reply@miralab.tr
SES_REPLY_TO=support@miralab.tr
SES_CONFIGURATION_SET=miralab-lms
DEV_SHOW_OTP=0
OTP_RATE_LIMIT_WINDOW_SECONDS=900
OTP_RATE_LIMIT_MAX_REQUESTS=5

REMINDERS_ENABLED=1
BOOKING_START_REMINDER_MINUTES=15
BOOKING_ENDING_REMINDER_MINUTES=15
NOTIFICATION_WORKER_INTERVAL_SECONDS=60
NOTIFICATION_RETRY_DELAY_MINUTES=5
NOTIFICATION_MAX_ATTEMPTS=3

BACKUP_DATABASE_PATH=/app/data/lab.sqlite
BACKUP_DIR=/app/data/backups
BACKUP_RETENTION_DAYS=30
